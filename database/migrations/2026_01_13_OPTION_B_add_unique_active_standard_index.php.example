<?php

use Illuminate\Database\Migrations\Migration;
use Illuminate\Database\Schema\Blueprint;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Facades\DB;

/**
 * OPCIÓN B: SOLUCIÓN COMPLEJA - Validación en app + índice compuesto
 *
 * Esta migración implementa la solución COMPLEJA donde:
 * - Una parte puede tener MÚLTIPLES estándares (historial)
 * - SOLO UNO puede estar activo (active=true) a la vez
 * - Los inactivos se mantienen como historial
 * - Usa índice compuesto para performance
 *
 * USAR CUANDO:
 * - Necesitas historial de cambios en estándares
 * - Necesitas auditoría y trazabilidad
 * - Quieres reportes históricos
 * - Planeas usar effective_date para versiones
 * - Contexto de manufactura con mejora continua
 *
 * IMPORTANTE:
 * - Renombra este archivo eliminando ".example" para activarlo
 * - Requiere implementar UniqueActiveStandard rule (ver documentación)
 * - Esta migración PRESERVA el historial
 */
return new class extends Migration
