        // PASO 1: Limpiar duplicados existentes
        // ESTRATEGIA: Mantener el más reciente (mayor created_at), eliminar los demás

        $duplicates = DB::table('standards')
            ->select('part_id', DB::raw('COUNT(*) as count'))
            ->groupBy('part_id')
            ->havingRaw('COUNT(*) > 1')
            ->pluck('part_id');

        foreach ($duplicates as $partId) {
            // Obtener el ID del estándar más reciente
            $keepId = DB::table('standards')
                ->where('part_id', $partId)
                ->orderBy('created_at', 'desc')
                ->value('id');

            // ELIMINAR todos los demás (HARD DELETE, no soft delete)
            DB::table('standards')
                ->where('part_id', $partId)
                ->where('id', '!=', $keepId)
                ->delete();

            echo "Part ID {$partId}: Kept standard #{$keepId}, deleted others\n";
        }

        // PASO 2: Agregar UNIQUE constraint
        Schema::table('standards', function (Blueprint $table) {
            $table->unique('part_id', 'unique_part_id');
