<?php
namespace App\Models;
use Illuminate\Database\Eloquent\Model;
use Illuminate\Database\Eloquent\Builder;
class StandardConfiguration extends Model
{
    /**
    /**
     * Tipos de estacion de trabajo soportados
     */
    public const TYPE_MANUAL = 'manual';
    public const TYPE_SEMI_AUTOMATIC = 'semi_automatic';
    public const TYPE_MACHINE = 'machine';
    /**
     * Maximo de personas permitido
     */
    public const MAX_PERSONS = 3;
    protected $fillable = [
        'standard_id',
        'workstation_type',
        'workstation_id',
        'persons_required',
        'units_per_hour',
        'is_default',
        'notes',
    ];
    protected $casts = [
        'standard_id' => 'integer',
        'workstation_id' => 'integer',
        'persons_required' => 'integer',
        'units_per_hour' => 'integer',
        'is_default' => 'boolean',
    ];
    // ==========================================
    // RELACIONES
    // ==========================================
    /**
     * Relacion con Standard padre
     */
    public function standard()
    {
        return $this->belongsTo(Standard::class);
    }
    /**
     * Relacion polimorfica con estacion de trabajo
     */
    public function workstation()
    {
        return match($this->workstation_type) {
            self::TYPE_MANUAL => $this->belongsTo(Table::class, 'workstation_id'),
            self::TYPE_SEMI_AUTOMATIC => $this->belongsTo(Semi_Automatic::class, 'workstation_id'),
            self::TYPE_MACHINE => $this->belongsTo(Machine::class, 'workstation_id'),
            default => null,
        };
    }
    // ==========================================
    // SCOPES
    // ==========================================
    /**
     * Filtrar por tipo de estacion
     */
    public function scopeByWorkstationType(Builder $query, string $type): Builder
    {
        return $query->where('workstation_type', $type);
    }
    /**
     * Filtrar por cantidad de personas
     */
    public function scopeByPersons(Builder $query, int $persons): Builder
    {
        return $query->where('persons_required', $persons);
    }
    /**
     * Obtener configuracion por defecto
     */
    public function scopeDefault(Builder $query): Builder
    public function scopeDefault(Builder $query): Builder
    {
        return $query->where('is_default', true);
    }
    /**
     * Ordenar por productividad descendente
     */
    public function scopeOrderByProductivity(Builder $query, string $direction = 'desc'): Builder
    {
        return $query->orderBy('units_per_hour', $direction);
    }
    // ==========================================
    // METODOS DE NEGOCIO
    // ==========================================
    /**
     * Validar que personas requeridas no excede capacidad de estacion
     */
    public function validateCapacity(): array
    {
        $workstation = $this->workstation;
        if (!$workstation) {
            return [
                'is_valid' => true,
                'message' => 'Sin estacion asignada',
            ];
        }
        $capacity = $workstation->employees ?? 0;
        $isValid = $this->persons_required <= $capacity;
        return [
            'is_valid' => $isValid,
            'message' => $isValid
                ? 'OK'
                : "Personas requeridas ({$this->persons_required}) excede capacidad ({$capacity})",
            'capacity' => $capacity,
        ];
    }
    /**
     * Calcular horas requeridas para una cantidad
     */
    public function calculateRequiredHours(int $quantity): float
    {
        if ($this->units_per_hour === 0) {
            throw new \DivisionByZeroError(
                "La configuracion tiene units_per_hour = 0"
            );
        }
        return round($quantity / $this->units_per_hour, 2);
    }
    /**
     * Obtener etiqueta descriptiva de la configuracion
     */
    public function getLabelAttribute(): string
    {
        $type = match($this->workstation_type) {
            self::TYPE_MANUAL => 'Mesa Manual',
            self::TYPE_SEMI_AUTOMATIC => 'Semi-Automatica',
            self::TYPE_MACHINE => 'Maquina',
            default => 'Desconocido',
        };
        return "{$type} - {$this->persons_required} persona(s) - {$this->units_per_hour} uph";
    }
    // ==========================================
    // METODOS ESTATICOS
    // ==========================================
    /**
     * Obtener tipos de estacion disponibles
     */
*/
public static function getWorkstationTypes(): array
{
return [
self::TYPE_MANUAL => 'Mesa de Trabajo Manual',
self::TYPE_SEMI_AUTOMATIC => 'Mesa Semi-Automatica',
self::TYPE_MACHINE => 'Maquina',
];
}
/**
* Obtener opciones de personas
*/
public static function getPersonsOptions(): array
{
return [
1 => '1 Persona',
2 => '2 Personas',
3 => '3 Personas',
];
}
}
