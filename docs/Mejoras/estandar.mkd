namespace App\Models;
class Standard extends Model
{
// ... codigo existente ...
// ==========================================
// NUEVAS RELACIONES
// ==========================================
/**
* Obtener todas las configuraciones del standard
*/
public function configurations()
{
return $this->hasMany(StandardConfiguration::class);
}
/**
* Obtener configuracion por defecto
*/
public function defaultConfiguration()
{
return $this->hasOne(StandardConfiguration::class)->where('is_default', true);
}
/**
* Obtener configuraciones por tipo de estacion
*/
public function configurationsByType(string $type)
{
return $this->configurations()->where('workstation_type', $type)->orderBy('persons_required');
}
// ==========================================
// NUEVOS METODOS DE NEGOCIO
// ==========================================
/**
* Obtener configuracion optima para empleados disponibles
*
* @param int $availableEmployees Empleados disponibles
* @param string|null $preferredType Tipo de estacion preferido
* @return StandardConfiguration|null
*/
public function getOptimalConfiguration(
int $availableEmployees,
?string $preferredType = null
?string $preferredType = null
): ?StandardConfiguration
{
$query = $this->configurations()->where('persons_required', '<=', $availableEmployees);
if ($preferredType) {
$query->where('workstation_type', $preferredType);
}
// Buscar la configuracion con mayor productividad
return $query->orderBy('units_per_hour', 'desc')->first();
}
/**
* Calcular horas requeridas con configuracion optima
*/
public function calculateRequiredHoursOptimal(
int $quantity,
int $availableEmployees,
?string $preferredType = null
): array
{
$config = $this->getOptimalConfiguration($availableEmployees, $preferredType);
if (!$config) {
throw new \RuntimeException(
"No hay configuracion disponible para {$availableEmployees} empleados"
);
}
return [
'hours' => $config->calculateRequiredHours($quantity),
'configuration' => $config,
'persons_used' => $config->persons_required,
'productivity' => $config->units_per_hour,
'workstation_type' => $config->workstation_type,
];
}
/**
* Verificar si el standard tiene configuraciones migradas
*/
public function hasMigratedConfigurations(): bool
{
return $this->configurations()->exists();
}
/**
* Obtener resumen de configuraciones para display
*/
public function getConfigurationsSummaryAttribute(): array
{
return $this->configurations()->select('workstation_type', 'persons_required', 'units_per_hour', 'is_default')->orderBy('workstation_type')->orderBy('persons_required')->get()->groupBy('workstation_type')->toArray();
}
}
