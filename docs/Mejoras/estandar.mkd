Query de Verificacion Post-Migracion Query de Verificacion Post-Migracion
-- Verificar standards migrados correctamente
SELECT
s.id as standard_id,
s.part_id,
p.number as part_number,
s.is_migrated,
COUNT(sc.id) as config_count,
GROUP_CONCAT(
CONCAT(sc.workstation_type, '-', sc.persons_required, 'p-', sc.units_per_hour, 'uph')
SEPARATOR ', '
) as configurations
FROM standards s
LEFT JOIN parts p ON s.part_id = p.id
LEFT JOIN standard_configurations sc ON s.id = sc.standard_id
WHERE s.deleted_at IS NULL
GROUP BY s.id, s.part_id, p.number, s.is_migrated
ORDER BY s.id;-- Verificar configuraciones que requieren revision
SELECT
sc.*,
s.part_id,
p.number as part_number
FROM standard_configurations sc
JOIN standards s ON sc.standard_id = s.id
JOIN parts p ON s.part_id = p.id
WHERE sc.notes LIKE '%REQUIERE REVISION%'
ORDER BY sc.standard_id;
