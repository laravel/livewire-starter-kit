<?php
namespace Database\Seeders;
use Illuminate\Database\Seeder;
use App\Models\Standard;
use App\Models\StandardConfiguration;
use Illuminate\Support\Facades\DB;
class MigrateStandardsToConfigurationsSeeder extends Seeder
{
public function run(): void
{
$this->command->info('Iniciando migracion de standards a configurations...');
$standards = Standard::whereNull('deleted_at')->where('is_migrated', false)->get();
$this->command->info("Standards a migrar: {$standards->count()}");
        $this->command->info("Standards a migrar: {$standards->count()}");
        $migrated = 0;
        $errors = [];
        DB::transaction(function () use ($standards, &$migrated, &$errors) {
            foreach ($standards as $standard) {
                try {
                    $this->migrateStandard($standard);
                    $migrated++;
                } catch (\Exception $e) {
                    $errors[] = [
                        'standard_id' => $standard->id,
                        'error' => $e->getMessage(),
                    ];
                }
            }
        });
        $this->command->info("Migracion completada: {$migrated} standards migrados");
        if (!empty($errors)) {
            $this->command->warn("Errores encontrados: " . count($errors));
            foreach ($errors as $error) {
                $this->command->error("Standard #{$error['standard_id']}: {$error['error']}");
            }
        }
    }
    protected function migrateStandard(Standard $standard): void
    {
        // Determinar tipo de estacion
        $workstationType = $this->determineWorkstationType($standard);
        $workstationId = $this->getWorkstationId($standard);
        // Crear configuraciones basadas en persons_1, persons_2, persons_3
        $configurations = [];
        // Configuracion para persons_1 (si existe)
        if ($standard->persons_1) {
            $configurations[] = [
                'standard_id' => $standard->id,
                'workstation_type' => $workstationType,
                'workstation_id' => $workstationId,
                'persons_required' => $standard->persons_1,
                'units_per_hour' => $standard->units_per_hour ?? 1,
                'is_default' => true,
                'notes' => 'Migrado automaticamente desde persons_1',
                'created_at' => now(),
                'updated_at' => now(),
            ];
        }
        // Configuracion para persons_2 (si existe y es diferente)
        if ($standard->persons_2 && $standard->persons_2 != $standard->persons_1) {
            $configurations[] = [
                'standard_id' => $standard->id,
                'workstation_type' => $workstationType,
                'workstation_id' => $workstationId,
                'persons_required' => $standard->persons_2,
                // NOTA: Usamos mismo units_per_hour porque no tenemos valor diferenciado
                'units_per_hour' => $standard->units_per_hour ?? 1,
                'is_default' => false,
                'notes' => 'Migrado automaticamente desde persons_2 - REQUIERE REVISION de units_per_hour',
                'created_at' => now(),
                'updated_at' => now(),
            ];
        }
        // Configuracion para persons_3 (si existe y es diferente)
        if ($standard->persons_3 &&
            $standard->persons_3 != $standard->persons_1 &&
            $standard->persons_3 != $standard->persons_2) {
            $configurations[] = [
                'standard_id' => $standard->id,
                'workstation_type' => $workstationType,
                'workstation_id' => $workstationId,
                'persons_required' => $standard->persons_3,
                'units_per_hour' => $standard->units_per_hour ?? 1,
                'units_per_hour' => $standard->units_per_hour ?? 1,
                'is_default' => false,
                'notes' => 'Migrado automaticamente desde persons_3 - REQUIERE REVISION de units_per_hour',
                'created_at' => now(),
                'updated_at' => now(),
            ];
        }
        // Si no hay configuraciones de personas, crear una por defecto
        if (empty($configurations)) {
            $configurations[] = [
                'standard_id' => $standard->id,
                'workstation_type' => $workstationType,
                'workstation_id' => $workstationId,
                'persons_required' => 1,
                'units_per_hour' => $standard->units_per_hour ?? 1,
                'is_default' => true,
                'notes' => 'Configuracion por defecto creada durante migracion',
                'created_at' => now(),
                'updated_at' => now(),
            ];
        }
        // Insertar configuraciones
        StandardConfiguration::insert($configurations);
        // Marcar standard como migrado
        $standard->update(['is_migrated' => true]);
    }
    protected function determineWorkstationType(Standard $standard): string
    {
        if ($standard->work_table_id) {
            return StandardConfiguration::TYPE_MANUAL;
        }
        if ($standard->semi_auto_work_table_id) {
            return StandardConfiguration::TYPE_SEMI_AUTOMATIC;
        }
        if ($standard->machine_id) {
            return StandardConfiguration::TYPE_MACHINE;
        }
        // Default a manual si no hay estacion asignada
        return StandardConfiguration::TYPE_MANUAL;
    }
    protected function getWorkstationId(Standard $standard): ?int
    {
        return $standard->work_table_id
            ?? $standard->semi_auto_work_table_id
            ?? $standard->machine_id;
    }
}
